  "keyFeatures": [
    "Real-time GitHub user profile search and analytics",
    "Repository explorer with filtering, sorting, and pagination",
    "Commit history viewer for any repository",
    "Language distribution visualization with interactive charts",
    "API rate limit monitoring with visual indicators",
    "GitHub Personal Access Token support (60 to 5,000 req/h)",
    "Dark mode with localStorage persistence",
    "Responsive design for mobile, tablet, and desktop",
    "Error handling for rate limits and API failures"
  ],
  "publicApiSurface": [
    "useGitHub.getUser(username)",
    "useGitHub.getRepos(username, page, per_page)",
    "useGitHub.getCommits(owner, repo, per_page)",
    "useGitHub.getLanguages(owner, repo)",
    "useGitHub.saveToken(token)",
    "useGitHub.rateLimit",
    "Header component",
    "SearchBar component",
    "UserCard component",
    "RepoList component",
    "CommitPanel component",
    "LanguageChart component",
    "TokenModal component",
    "ErrorBanner component"
  ]
